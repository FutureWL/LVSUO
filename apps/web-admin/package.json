    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.0.0",
    "happy-dom": "^15.0.0",
    "sass": "^1.74.0",
    "typescript": "^5.4.0",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.26.0",
