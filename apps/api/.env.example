# =============================================================
# LM Unity · Counsel API · 环境变量模板
# 复制为 .env 后修改:  cp .env.example .env
# =============================================================
# 启动时由 common/config/required-env.ts 校验:
#   - [必填] 缺了直接抛错,服务起不来
#   - [弱校] 强度不足只 warn(开发可忽略,生产请改)
#   - [可选] 不校验
# =============================================================


# ============ App ============
# [可选] 运行环境 development | production | test
NODE_ENV=development

# [可选] HTTP 端口,默认 37000
APP_PORT=37000

# [可选] 全局路由前缀,默认 api/counsel/v1
APP_GLOBAL_PREFIX=api/counsel/v1

# [可选] CORS 白名单,逗号分隔;空 = 全部允许(仅 dev)
# [必填-PROD] 生产必须显式声明,例如:
# APP_CORS_ORIGINS=https://app.example.com,https://admin.example.com
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:5174


# ============ Database (PostgreSQL) ============
# [必填] Prisma 用,缺了启动就崩
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lmsuo?schema=public


# ============ Redis ============
# [可选] 缓存 / 会话,后续模块会用到
REDIS_URL=redis://localhost:6379


# ============ JWT ============
# [必填] [弱校-长度≥32] HS256 至少 32 字符
#   生产环境必须换成随机强密钥,例如:
#     node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-strong-secret-min-32-chars

# [可选] access token 过期时间,默认 7d
JWT_EXPIRES_IN=7d

# [可选] refresh token 过期时间,默认 30d
JWT_REFRESH_EXPIRES_IN=30d


# ============ MinIO (S3-compatible 对象存储) ============
# [可选] 案件文档 / 附件,任务书第 8 章附件相关
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lmsuo


# ============ AI (云端大模型) ============
# [可选] L6 AI 辅助(律时对话 / 合规审查),后续模块用
#   provider: openai | deepseek | qwen
AI_PROVIDER=qwen
AI_API_KEY=replace-with-your-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-turbo


# ============ Logging ============
# [可选] pino 日志级别 trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# [可选] 开发环境是否美化日志(true / false)
LOG_PRETTY=true
